# shellfmt can't handle a lot of actual zsh syntax
[*.zsh]
ignore = true

[justfile]
indent_style = space
indent_size = 4

[*.{yaml,yml}]
indent_style = space
indent_size = 2

[*.sh]
indent_size = 4

[*]
indent_style = space
indent_size = 4
tab_width = 2
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
